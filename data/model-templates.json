[
  {
    "id": "markov-chronic",
    "name": "慢性病长期Markov模型",
    "description": "适用于糖尿病、CKD、心衰等慢性病的长期成本-效果分析",
    "model_type": "markov",
    "states": ["健康/稳定", "并发症", "严重并发症", "死亡"],
    "cycle_length": 1,
    "cycle_unit": "年",
    "num_cycles": 30,
    "half_cycle_correction": true,
    "discount_rate": 0.03,
    "use_cases": ["2型糖尿病", "慢性肾病", "心力衰竭", "高血压"],
    "parameters": {
      "transition_probabilities": {
        "健康->并发症": {"distribution": "beta", "alpha": 2, "beta": 98},
        "健康->死亡": {"distribution": "beta", "alpha": 1, "beta": 999},
        "并发症->严重并发症": {"distribution": "beta", "alpha": 5, "beta": 95},
        "并发症->死亡": {"distribution": "beta", "alpha": 3, "beta": 97},
        "严重并发症->死亡": {"distribution": "beta", "alpha": 15, "beta": 85}
      },
      "costs": {
        "健康": {"distribution": "gamma", "mean": 5000, "se": 500},
        "并发症": {"distribution": "gamma", "mean": 25000, "se": 2500},
        "严重并发症": {"distribution": "gamma", "mean": 80000, "se": 8000}
      },
      "utilities": {
        "健康": {"distribution": "beta", "alpha": 85, "beta": 15},
        "并发症": {"distribution": "beta", "alpha": 65, "beta": 35},
        "严重并发症": {"distribution": "beta", "alpha": 40, "beta": 60}
      }
    },
    "reference": "Briggs AH, et al. Decision Modelling for Health Economic Evaluation. 2006."
  },
  {
    "id": "partitioned-survival-oncology",
    "name": "肿瘤分区生存模型",
    "description": "基于PFS/OS曲线的肿瘤药物评价标准模型",
    "model_type": "partitioned_survival",
    "states": ["PFS", "PD", "Death"],
    "cycle_length": 1,
    "cycle_unit": "月",
    "num_cycles": 60,
    "half_cycle_correction": true,
    "discount_rate": 0.03,
    "use_cases": ["肺癌", "乳腺癌", "结直肠癌", "黑色素瘤"],
    "parameters": {
      "survival_curves": {
        "PFS": {
          "distribution": "weibull",
          "lambda": 0.085,
          "gamma": 0.95,
          "alternative": ["log-normal", "log-logistic", "gompertz"]
        },
        "OS": {
          "distribution": "weibull",
          "lambda": 0.045,
          "gamma": 0.88,
          "alternative": ["log-normal", "log-logistic", "gompertz"]
        }
      },
      "costs": {
        "PFS": {"distribution": "gamma", "mean": 35000, "se": 3500, "unit": "月"},
        "PD": {"distribution": "gamma", "mean": 25000, "se": 2500, "unit": "月"}
      },
      "utilities": {
        "PFS": {"distribution": "beta", "alpha": 65, "beta": 35},
        "PD": {"distribution": "beta", "alpha": 45, "beta": 55}
      }
    },
    "reference": "Latimer NR. Survival Analysis for Economic Evaluations Alongside Clinical Trials. Pharmacoeconomics. 2013."
  },
  {
    "id": "microsimulation-heterogeneity",
    "name": "个体异质性微观模拟",
    "description": "适用于需要考虑个体差异的复杂场景",
    "model_type": "microsimulation",
    "states": ["健康", "轻度", "中度", "重度", "死亡"],
    "cycle_length": 1,
    "cycle_unit": "年",
    "num_cycles": 40,
    "half_cycle_correction": false,
    "discount_rate": 0.03,
    "num_patients": 10000,
    "use_cases": ["骨质疏松症", "阿尔茨海默病", "帕金森病"],
    "parameters": {
      "patient_characteristics": {
        "age": {"distribution": "normal", "mean": 65, "sd": 10},
        "gender": {"distribution": "bernoulli", "p_male": 0.45},
        "baseline_risk": {"distribution": "lognormal", "mean": 0, "sd": 0.5}
      },
      "transition_probabilities": {
        "age_dependent": true,
        "risk_factors": ["age", "gender", "comorbidities"]
      },
      "costs": {
        "fixed": {"健康": 2000, "轻度": 8000, "中度": 25000, "重度": 80000},
        "variable": {"per_year_increase": 0.05}
      },
      "utilities": {
        "baseline": {"健康": 0.88, "轻度": 0.72, "中度": 0.55, "重度": 0.35},
        "age_adjustment": -0.002
      }
    },
    "reference": "Siebert U, et al. State-Transition Modeling in Medical Decision Making. Med Decis Making. 2012."
  },
  {
    "id": "budget-impact-payer",
    "name": "医保预算影响模型",
    "description": "评估新药纳入医保后的基金支出影响",
    "model_type": "budget_impact",
    "time_horizon": 5,
    "perspective": "payer",
    "use_cases": ["新药医保准入", "适应症扩展", "仿制药替代"],
    "parameters": {
      "population": {
        "total_eligible": 1000000,
        "diagnosis_rate": 0.65,
        "treatment_rate": 0.45
      },
      "market_share": {
        "year_1": {"new_drug": 0.05, "existing": 0.95},
        "year_2": {"new_drug": 0.15, "existing": 0.85},
        "year_3": {"new_drug": 0.25, "existing": 0.75},
        "year_4": {"new_drug": 0.30, "existing": 0.70},
        "year_5": {"new_drug": 0.35, "existing": 0.65}
      },
      "costs": {
        "new_drug": {"annual": 120000, "administration": 5000},
        "existing": {"annual": 45000, "administration": 3000}
      },
      "discount_rate": 0.03
    },
    "reference": "Sullivan SD, et al. Budget Impact Analysis—Principles of Good Practice. Value Health. 2012."
  },
  {
    "id": "network-meta-analysis",
    "name": "网络Meta分析模型",
    "description": "间接比较多干预措施的相对效果",
    "model_type": "network_meta",
    "use_cases": ["多靶向药物比较", "免疫治疗排序", "联合方案评价"],
    "parameters": {
      "outcomes": ["ORR", "PFS", "OS", "Grade 3+ AE"],
      "comparators": ["标准治疗", "Drug A", "Drug B", "Drug C"],
      "model": {
        "type": "random_effects",
        "prior": {"mu": "normal(0, 10000)", "tau": "uniform(0, 5)"}
      },
      "consistency_check": true,
      "ranking_methods": ["SUCRA", "P_best", "rankogram"]
    },
    "reference": "Dias S, et al. Network Meta-Analysis for Decision Making. John Wiley & Sons. 2018."
  },
  {
    "id": "sensitivity-analysis-suite",
    "name": "敏感性分析套件",
    "description": "包含PSA、TOWSA、情景分析的完整分析套件",
    "model_type": "sensitivity_suite",
    "use_cases": ["所有经济评价", "不确定性量化", "决策稳健性检验"],
    "parameters": {
      "psa": {
        "n_simulations": 10000,
        "sampling_method": "lhs",
        "random_seed": 42,
        "output": ["ICER", "INB", "CEAC", "EVPI"]
      },
      "towsa": {
        "parameters": "all",
        "range": "±30%",
        "output": "tornado_diagram"
      },
      "scenario_analysis": {
        "scenarios": [
          {"name": "Base Case", "description": "最可能的参数组合"},
          {"name": "Best Case", "description": "干预效果最好"},
          {"name": "Worst Case", "description": "干预效果最差"},
          {"name": "High Cost", "description": "成本最高情景"},
          {"name": "Low Cost", "description": "成本最低情景"}
        ]
      }
    },
    "reference": "Briggs AH, et al. Probabilistic Sensitivity Analysis for Decision Trees. Pharmacoeconomics. 2005."
  }
]
